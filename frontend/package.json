{
  "name": "urbapf-frontend",
  "version": "1.0.0",
  "description": "UrbaPF Frontend - Quasar",
  "productName": "UrbaPF",
  "author": "UrbaPF Team",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint --ext .ts,.vue src --ignore-pattern 'src/env.d.ts'",
    "format": "prettier --write \"src/**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.14.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "quasar": "^2.19.2",
    "vue": "^3.5.31",
    "vue-i18n": "^9.14.5",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
