{
  "name": "urbapf-frontend",
  "version": "1.0.0",
  "description": "UrbaPF Frontend - Quasar",
  "productName": "UrbaPF",
  "author": "UrbaPF Team",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint --ext .js,.ts,.vue src --ignore-pattern 'src/env.d.ts'",
    "format": "prettier --write \"src/**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "axios": "^1.6.7",
    "pinia": "^2.1.7",
    "quasar": "^2.18.6",
    "vue": "^3.4.18",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/vite-plugin": "^1.10.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sass": "^1.71.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": "^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
