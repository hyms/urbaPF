# Frontend Environment Variables (for local Vite/Quasar development)

VITE_API_URL=/api # Base URL for API requests. Use relative path for Nginx proxying in production.
VITE_API_BASE_URL=/api # Base URL for API requests. Use relative path for Nginx proxying in production.
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY # Your Google Maps API key
