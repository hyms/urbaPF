PEM_PATH=/path/to/your/key.pem
SERVER_ADDRESS=your-ec2-server-address.compute-1.amazonaws.com

# Database Configuration (for Docker Compose and Backend)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=urbapf_db
DB_USER=urbapf_user
DB_PASSWORD=your_db_password

# JWT Configuration (for Backend)
JWT_SECRET=your_jwt_secret_key_at_least_32_chars
JWT_EXPIRY_DAYS=7

# OneSignal (Push Notifications) Configuration (for Backend)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# Frontend Build Configuration (for local development with Vite/Quasar)
VITE_API_URL=/api # Use relative path for Nginx proxying in production
VITE_API_BASE_URL=/api # Use relative path for Nginx proxying in production

# ASP.NET Core Environment (for Backend)
ASPNETCORE_ENVIRONMENT=Development # Set to Production for production deployments
