# Development - .NET 10 con Hot Reload
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS development
WORKDIR /app

COPY backend/UrbaPF.sln ./
COPY backend/Api/*.csproj ./Api/
COPY backend/Domain/*.csproj ./Domain/
COPY backend/Infrastructure/*.csproj ./Infrastructure/
COPY backend/tests/*.csproj ./tests/
RUN dotnet restore

COPY backend/ .

WORKDIR /app/Api
RUN dotnet build -c Debug

ENV DOTNET_RUNNING_IN_CONTAINER=true
ENV ASPNETCORE_ENVIRONMENT=Development

EXPOSE 5000

# Ejecutar en modo debug
CMD ["dotnet", "run", "--no-build", "--urls", "http://+:5000"]
